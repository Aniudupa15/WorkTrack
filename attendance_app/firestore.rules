rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────
    function isAuth() { return request.auth != null; }
    function uid()    { return request.auth.uid; }
    function isAdmin(compId) {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid()))
          .data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(uid()))
          .data.companyId == compId;
    }
    function isEmployee(compId, empId) {
      return isAuth() && uid() == empId &&
        get(/databases/$(database)/documents/users/$(uid()))
          .data.companyId == compId;
    }

    // ── Users (role doc) ────────────────────────
    match /users/{userId} {
      allow read:  if isAuth() && uid() == userId;
      allow write: if isAuth() && uid() == userId;
    }

    // ── Companies ───────────────────────────────
    match /companies/{companyId} {
      allow read, write: if isAdmin(companyId);

      // ── Employees ─────────────────────────────
      match /employees/{empId} {
        allow read:  if isAdmin(companyId) || isEmployee(companyId, empId);
        allow write: if isAdmin(companyId);
      }

      // ── Attendance ────────────────────────────
      match /attendance/{docId} {
        allow read:   if isAdmin(companyId) ||
                         isEmployee(companyId, resource.data.employeeId);
        allow create: if isEmployee(companyId, request.resource.data.employeeId);
        allow update: if isAdmin(companyId) ||
                         isEmployee(companyId, resource.data.employeeId);
        allow delete: if isAdmin(companyId);
      }

      // ── Leaves ────────────────────────────────
      match /leaves/{docId} {
        allow read:   if isAdmin(companyId) ||
                         isEmployee(companyId, resource.data.employeeId);
        allow create: if isEmployee(companyId, request.resource.data.employeeId);
        allow update: if isAdmin(companyId);
      }
    }

    // ── Notifications ───────────────────────────
    match /notifications/{docId} {
      allow read: if isAuth();
    }
  }
}
